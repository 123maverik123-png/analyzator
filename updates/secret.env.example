# Скопируйте этот файл в secret.env и заполните значения. secret.env в .gitignore.

# --- YandexGPT (для анализа) ---
YC_API_KEY=ваш_api_ключ
YC_FOLDER_ID=ваш_folder_id

# --- Диаризация (разделение голосов оператор/абонент в моно-записи) ---
# 1. Создайте токен на hf.co/settings/tokens
# 2. Примите условия доступа на странице huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=ваш_huggingface_токен
# Поставьте 0, чтобы отключить диаризацию (например, не хватает ресурсов ПК).
DIARIZATION_ENABLED=1

# --- Идентификация оператора (на каждом ПК своё значение) ---
# Если не задать — возьмётся имя компьютера.
OPERATOR_ID=op-ivanov

# --- Связь с центром (WireGuard-адрес центральной машины) ---
# Если оставить пустым — клиент работает автономно (только локальная БД).
CENTRAL_URL=http://10.8.0.1:8000
# Общий секрет, ОДИНАКОВЫЙ на всех клиентах и на сервере.
CENTRAL_TOKEN=придумайте_длинный_общий_секрет
# Для самоподписанного HTTPS внутри WireGuard можно отключить проверку сертификата:
# CENTRAL_VERIFY_TLS=0
